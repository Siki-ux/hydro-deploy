##############################################################################

TIMEIO_IMAGE_REGISTRY=registry.hzdr.de/ufz-tsm/tsm-orchestration

TIMEIO_INIT_IMAGE_TAG=2026-01-20
TIMEIO_FROST_IMAGE_TAG=2026-01-20
