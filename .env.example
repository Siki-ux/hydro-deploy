##############################################################################
# Hydro Platform — Unified Environment Configuration
# =============================================================================
# Copy to .env and fill in real values before first run:
#   cp .env.example .env
#   ./scripts/generate-secrets.sh   # fills in all @generate fields
#
# This single file is symlinked into both repos:
#   ../tsm-orchestration/.env -> ../../hydro-deploy/.env
#   ../water-dp/.env          -> ../../hydro-deploy/.env
#
# Annotations:
#   @generate  — run generate-secrets.sh to fill this in securely
#   @sync      — same value used under a different name in the other repo
#                (both names are listed here so both repos read it correctly)
#   @tunnel    — only needed when running with Cloudflare Tunnel
##############################################################################


##############################################################################
# PUBLIC ACCESS
##############################################################################

# Hostname/IP that end-users hit in their browser.
# Local development: localhost
# With Cloudflare Tunnel: your domain, e.g. hydro.example.com
PUBLIC_HOSTNAME=localhost

# Host port the proxy binds to.  Set to 80 on a server where port 80 is free;
# use 8080 on Windows (port 80 is often taken by http.sys / Hyper-V).
# All derived URLs (PROXY_URL, KEYCLOAK_EXTERNAL_URL, …) read this value,
# so changing it once adjusts the whole stack.
PUBLIC_PORT=8080

# Keycloak external URL seen by the browser (OIDC redirects go here).
# Derived from PUBLIC_HOSTNAME + PUBLIC_PORT. Update when changing either.
KEYCLOAK_EXTERNAL_URL=http://localhost:8080/keycloak

# @tunnel — token from the Cloudflare Zero Trust dashboard
# Leave empty if not using the tunnel
CLOUDFLARE_TUNNEL_TOKEN=


##############################################################################
# BUILD — Corporate TLS Inspection / SSL Bypass
# =============================================================================
# Set SKIP_SSL_VERIFY=true if your network performs TLS inspection (corporate
# proxy / firewall that re-signs HTTPS traffic with an internal CA).
# This adds --trusted-host / --no-check-certificate / NODE_TLS_REJECT_UNAUTHORIZED=0
# to Docker build stages.  Leave false for clean networks and CI pipelines.
##############################################################################
SKIP_SSL_VERIFY=false


##############################################################################
# DATABASE (TimescaleDB / PostgreSQL)
# Used by: TSM stack, water-dp API, MQTT auth
##############################################################################

# @generate
DATABASE_ADMIN_USER=postgres
DATABASE_ADMIN_PASSWORD=changeme      # TSM: DATABASE_ADMIN_PASSWORD

DATABASE_USER=postgres
DATABASE_PASSWORD=changeme            # @sync water-dp: DATABASE_PASSWORD
DATABASE_NAME=postgres
DATABASE_PORT=5432

# water-dp's own app database (separate schema on the same cluster)
POSTGRES_DB=water_app
DATABASE_URL=postgresql://postgres:changeme@database:5432/postgres?options=-csearch_path=water_dp,public  # @derive — overridden by docker-compose.yml

# TimeIO DB connection (water-dp -> TSM database)
TIMEIO_DB_HOST=database
TIMEIO_DB_PORT=5432
TIMEIO_DB_USER=postgres
TIMEIO_DB_PASSWORD=changeme           # must equal DATABASE_PASSWORD above
TIMEIO_DB_NAME=postgres

# Database persistence — "database" = named Docker volume, or set an absolute path
DATABASE_PERSISTENCE_VOLUME=database
DATABASE_UID=1000
DATABASE_GID=1000


##############################################################################
# ENCRYPTION
# Must be identical in TSM and water-dp.
##############################################################################

# @generate — 32-byte URL-safe base64 key
FERNET_ENCRYPTION_SECRET=changeme


##############################################################################
# OBJECT STORAGE (MinIO)
##############################################################################

# @generate
OBJECT_STORAGE_ROOT_USER=minioadmin
OBJECT_STORAGE_ROOT_PASSWORD=changeme

# MinIO bucket browser redirect (for TSM proxy)
OBJECT_STORAGE_BROWSER_REDIRECT_URL=http://localhost/object-storage/

# water-dp connects to MinIO using these variables (same values as above)
MINIO_URL=object-storage:9000
MINIO_ACCESS_KEY=${OBJECT_STORAGE_ROOT_USER}
MINIO_SECRET_KEY=${OBJECT_STORAGE_ROOT_PASSWORD}
MINIO_SECURE=false


##############################################################################
# MQTT (Mosquitto)
# @sync — TSM and water-dp use different variable names for the same user
##############################################################################

# @generate
# TSM variable names (frontendbus = the user water-dp connects as)
THING_MANAGEMENT_MQTT_USER=frontendbus
THING_MANAGEMENT_MQTT_PASS=changeme

# water-dp variable names (must match THING_MANAGEMENT_MQTT_* above)
MQTT_USERNAME=frontendbus
MQTT_PASSWORD=changeme

# MQTT broker auth PostgreSQL connection (used by mosquitto-go-auth plugin)
MQTT_AUTH_POSTGRES_USER=mqtt_auth
MQTT_AUTH_POSTGRES_PASS=changeme
MQTT_AUTH_POSTGRES_DB=postgres
MQTT_AUTH_PG_TLSMODE=disable

# MQTT ingest worker credentials (internal, not exposed to water-dp)
MQTT_INGEST_USER=mqtt_ingest
MQTT_INGEST_PASSWORD=changeme        # @generate

MQTT_PORT=1883
MQTT_BROKER_HOST=mqtt-broker
MQTT_PERSISTENCE_VOLUME=mqtt-broker
MQTT_BROKER_UID=1000


##############################################################################
# KEYCLOAK
# @sync — TSM and water-dp use different variable names
##############################################################################

# @generate
# TSM variable names
KEYCLOAK_ADMIN_USER=keycloak
KEYCLOAK_ADMIN_PASS=changeme

# water-dp variable names (must match above)
KEYCLOAK_ADMIN_USERNAME=keycloak
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak internal database
KEYCLOAK_DATABASE_USER=keycloak
KEYCLOAK_DATABASE_PASS=changeme      # @generate

# Keycloak internal URL (container-to-container)
KEYCLOAK_URL=http://keycloak:8081/keycloak


##############################################################################
# WATER-DP APPLICATION SECRETS
##############################################################################

# @generate — JWT signing key (min 32 chars)
SECRET_KEY=changeme

# @generate — NextAuth session encryption
AUTH_SECRET=changeme
NEXTAUTH_SECRET=changeme

# GeoServer
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver   # @generate for production
GEOSERVER_WORKSPACE=water_data
GEOSERVER_DB_SCHEMA=water_dp_geo
GEOSERVER_URL=http://water-dp-geoserver:8080/geoserver

# Seed admin (must exist in Keycloak with realm-admin role)
SEED_ADMIN_USERNAME=admin-siki
SEED_ADMIN_PASSWORD=changeme


##############################################################################
