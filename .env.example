##############################################################################
# PROXY / NGINX
##############################################################################

# Derived from PUBLIC_HOSTNAME + PUBLIC_PORT — update when changing either.
PROXY_URL=http://localhost:8080
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
PROXY_HTTPS_ENABLED=false
PROXY_HTTPS_REDIRECT=false
PROXY_LETSENCRYPT_EMAIL=
PROXY_HTTPS_PATHS=
# Maps the host PUBLIC_PORT to the container's internal port 80.
# Update the first port when changing PUBLIC_PORT.
PROXY_PLAIN_PORT_MAPPING=127.0.0.1:8080:80
PROXY_TLS_PORT_MAPPING=127.0.0.1:443:443
PROXY_MINIO_PORT_MAPPING=127.0.0.1:9000:9000
PROXY_SITE_CONFIG_FILE=tsm.local.conf
PROXY_TLS_CERT_PATH=/tmp/c8cf2d92-73cd-11ec-b035-54e1ad7c5c19
PROXY_TLS_KEY_PATH=/tmp/c8cf2d92-73cd-11ec-b035-54e1ad7c5c19
PROXY_MAX_LOG_FILE_SIZE=150m


##############################################################################
# SERVICE BEHAVIOUR
##############################################################################

LOG_LEVEL=INFO
DEBUG=true                                    # Production: set to false
SQLALCHEMY_LOG_LEVEL=WARNING                   # Set to DEBUG to log all SQL queries
CORS_ORIGINS=["*"]                              # Production: set to ["https://yourdomain.com"]
ALLOWED_HOSTS=*                                 # Production: set to yourdomain.com
GEOSERVER_CSRF_DISABLED=true                    # Production: set to false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600                      # Recycle DB connections after 1 hour
DATABASE_CONNECT_TIMEOUT=30                     # Seconds before DB connect gives up
WEB_CONCURRENCY=4                               # Gunicorn worker count
SERVICE_RESTART_POLICY=unless-stopped
SERVICE_BACKGROUND_RESTART_POLICY=on-failure:3
SERVICE_WORKER_RESTART_POLICY=on-failure:3
SERVICE_WORKER_RESTART_MAX_ATTEMPTS=10
SERVICE_WORKER_RESTART_WINDOW_SECONDS=120

UID=1000
GID=1000

TIME_ZONE=UTC
MAX_TIME_RANGE_DAYS=365

ACCESS_TOKEN_EXPIRE_MINUTES=30
API_PREFIX=/api/v1

# Init container flags
INIT_USE_CHOWN=true
INIT_USE_CHOWN_OBJECT_STORAGE=true

# Log size defaults
DEFAULT_MAX_LOG_FILE_SIZE=10m
DEFAULT_MAX_LOG_FILE_COUNT=2
WORKER_RUN_QAQC_MAX_LOG_FILE_SIZE=100m
WROKER_FILE_INGEST_MAX_LOG_FILE_SIZE=30m
DB_API_MAX_LOG_FILE_SIZE=25m
CRON_SCHEDULER_MAX_LOG_FILE_SIZE=3g
MQTT_CAT_LOG_SIZE=100K
MQTT_CAT_FILE_COUNT=10
MQTT_BROKER_LOG_SIZE=100K
MQTT_BROKER_FILE_COUNT=10


