TIMEIO_CRON_SCHEDULER_IMAGE_TAG=2026-01-20
TIMEIO_PROXY_IMAGE_TAG=2026-02-06

DB_API_IMAGE_TAG=2026-02-10-150902

# Base images (usually no need to change)
INIT_ALPINE_BASE_IMAGE_REGISTRY=alpine
INIT_ALPINE_BASE_IMAGE_TAG=3.21
DATABASE_POSTGRES_IMAGE_REGISTRY=postgis/postgis
