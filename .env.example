MQTT_BROKER_MOSQUITTO_IMAGE_REGISTRY=iegomez/mosquitto-go-auth
MQTT_BROKER_MOSQUITTO_IMAGE_TAG=2.1.0-mosquitto_1.6.14
MQTT_CAT_MOSQUITTO_IMAGE_REGISTRY=eclipse-mosquitto
